# ---------------------------------------------------------------------------
# RV Defect Intelligence — environment variables (see CLAUDE.md §11)
# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# ---------------------------------------------------------------------------

# --- Edge Function secrets (server-side only; set via `supabase secrets set`) ---
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=        # ingestion only, never shipped to client
AGENT_DB_URL=                     # connection string for the read-only agent_readonly role

# --- Frontend (public, safe to expose) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_ASK_FUNCTION_URL=
